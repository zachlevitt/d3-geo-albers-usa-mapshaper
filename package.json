{
  "name": "d3-geo-albers-usa-mapshaper",
  "description": "A D3.js composite projection that exactly replicates mapshaper's albersusa projection.",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "jsdelivr": "dist/d3-geo-albers-usa-mapshaper.min.js",
  "unpkg": "dist/d3-geo-albers-usa-mapshaper.min.js",
  "exports": {
    "import": "./dist/index.mjs",
    "require": "./dist/index.cjs"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "d3",
    "d3-module",
    "geo",
    "maps",
    "cartography",
    "projection",
    "albers",
    "usa",
    "mapshaper"
  ],
  "author": {
    "name": "Zach Levitt",
    "url": "https://zachlevitt.com"
  },
  "license": "ISC",
  "sideEffects": false,
  "dependencies": {
    "d3-geo": "^3.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@rollup/plugin-terser": "^0.4.4",
    "eslint": "^9.35.0",
    "mocha": "^10.8.2",
    "rollup": "^3.29.5"
  },
  "scripts": {
    "prepublishOnly": "rm -rf dist && rollup -c"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
